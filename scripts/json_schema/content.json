{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "pattern": "^https?://[^\\s]+[^/\\s]$"
    },
    "rss_feed": {
      "type": "string",
      "pattern": "^https?://[^\\s]+[^/\\s]$"
    },
    "type": {
      "type": "string"
    },
    "photo_url": {
      "type": "string",
      "pattern": "^https?://[^\\s]+[^/\\s]$"
    },
    "description": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "social_media": {
              "type": "array",
              "items": [
                {
                  "type": "object",
                  "properties": {
                    "twitter": {
                      "type": "string"
                    },
                    "mastodon": {
                      "type": "string"
                    },
                    "bluesky": {
                      "type": "string"
                    },
                    "linkedin": {
                      "type": "string"
                    },
                    "facebook": {
                      "type": "string"
                    },
                    "github": {
                      "type": "string"
                    },
                    "instagram": {
                      "type": "string"
                    },
                    "youtube": {
                      "type": "string"
                    },
                    "tiktok": {
                      "type": "string"
                    },
                    "periscope": {
                      "type": "string"
                    },
                    "researchgate": {
                      "type": "string"
                    },
                    "website": {
                      "type": "string",
                      "pattern": "^https?://[^\\s]+[^/\\s]$"
                    },
                    "orcid": {
                      "type": "string"
                    }
                  }
                }
              ]
            }
          },
          "required": ["name"]
        }
      ]
    }
  },
  "required": ["title", "url", "type", "authors", "language"]
}
